# ────────── Ansible ──────────
*.retry
*.log

# If using encrypted variables or secrets
vault.yml
vault_pass.txt
secrets.yml
.env

# Inventory artifacts (for dynamic/auto-generated inventory)
inventory.dynamic
hosts

# ────────── SSH Keys ──────────
# NEVER commit private keys. Public keys are low-risk but excluded
# as a habit – regenerate from the actual key when needed.
id_rsa
id_rsa.pub
*.pem
*.key

# ────────── Python ──────────
__pycache__/
*.pyc
*.pyo
*.pyd
venv/

# ────────── Docker ──────────
*.tar
*.img
*.pid
*.sock
*.gz
*.tar.gz
*.tar.bz2

# ────────── Editor & System Files ──────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ────────── Windows/WSL Artifacts ──────────
*.lnk
$RECYCLE.BIN/
System Volume Information/

# ────────── IDE/Editor Metadata ──────────
.vscode/
.idea/

# ────────── Swap/Backup Files ──────────
*.swp
*.swo
*.bak
*.tmp
*.old

# ────────── Testing Frameworks (optional future) ──────────
.molecule/
testinfra/

# Molecule role symlink (created by: ln -sfn ../../../.. roles/webserver/molecule/default/roles)
roles/webserver/molecule/default/roles
