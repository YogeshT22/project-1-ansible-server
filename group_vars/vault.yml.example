---
# group_vars/vault.yml  <- TEMPLATE (unencrypted placeholder)
# HOW TO USE:
# 1. Copy: cp group_vars/vault.yml.example group_vars/vault.yml
# 2. Fill in real values below.
# 3. Encrypt: ansible-vault encrypt group_vars/vault.yml
# 4. Run: ansible-playbook playbook.yml --ask-vault-pass
# NOTE: vault.yml is in .gitignore - it will NEVER be committed.
vault_server_admin_email: "your-real-email@example.com"
