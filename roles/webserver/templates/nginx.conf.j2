# nginx.conf – managed by Ansible (webserver role)
# Do NOT edit this file manually on the server; changes will be overwritten.

user www-data;
worker_processes auto;
pid /run/nginx.pid;
include /etc/nginx/modules-enabled/*.conf;

events {
    # Production standard: handles 1024 simultaneous connections per worker.
    worker_connections {{ webserver_worker_connections }};
    multi_accept on;
}

http {
    # ── Performance ──────────────────────────────────────────
    sendfile           on;
    tcp_nopush         on;
    tcp_nodelay        on;
    keepalive_timeout  65;
    types_hash_max_size 2048;
    server_tokens      off;   # Do not reveal Nginx version in headers/errors

    include      /etc/nginx/mime.types;
    default_type application/octet-stream;

    # ── TLS ──────────────────────────────────────────────────
    # TLSv1 and TLSv1.1 are deprecated (RFC 8996) – only 1.2 and 1.3 allowed.
    ssl_protocols             TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers               HIGH:!aNULL:!MD5;

    # ── Logging ───────────────────────────────────────────────
    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log warn;

    # ── Compression ───────────────────────────────────────────
    gzip              on;
    gzip_vary         on;
    gzip_proxied      any;
    gzip_comp_level   6;
    gzip_types        text/plain text/css text/xml application/json
                      application/javascript application/rss+xml
                      application/atom+xml image/svg+xml;

    # ── Default server block ──────────────────────────────────
    server {
        listen      80 default_server;
        listen      [::]:80 default_server;

        root        /var/www/html;
        index       index.html index.htm;

        server_name {{ webserver_server_name }};

        # ── Security headers (OWASP recommended) ─────────────
        add_header X-Frame-Options           "SAMEORIGIN"            always;
        add_header X-Content-Type-Options    "nosniff"               always;
        add_header X-XSS-Protection          "1; mode=block"         always;
        add_header Referrer-Policy           "strict-origin-when-cross-origin" always;
        add_header Content-Security-Policy   "default-src 'self'"    always;
        add_header Permissions-Policy        "geolocation=(), microphone=()" always;

        location / {
            try_files $uri $uri/ =404;
        }

        # Block access to hidden files (e.g. .git, .env)
        location ~ /\. {
            deny all;
        }
    }
}
